# ============================================================
# Пример конфигурации окружения
# Скопируй этот файл: cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# ОБЯЗАТЕЛЬНО ЗАМЕНИ ПЕРЕД ПРОДОМ
# ------------------------------------------------------------

# Секретный ключ Django — уникальная случайная строка.
# Значение ниже сгенерировано для примера, ЗАМЕНИ перед деплоем!
SECRET_KEY=django-insecure-replace-this-with-a-real-secret-key-before-production

# Режим отладки. В продакшне ВСЕГДА должен быть False.
DEBUG=True

# Список разрешённых хостов через запятую.
# В продакшне укажи реальный домен, например: example.com,www.example.com
ALLOWED_HOSTS=127.0.0.1,localhost

# ------------------------------------------------------------
# БАЗА ДАННЫХ
# ------------------------------------------------------------

# По умолчанию используется SQLite — никакой дополнительной настройки не нужно.
# DATABASE_URL не задан → Django создаст файл db.sqlite3 в корне проекта.

# Чтобы переключиться на PostgreSQL, раскомментируй строку ниже
# и укажи свои реквизиты подключения:
# DATABASE_URL=postgres://user:password@localhost:5432/dbname

# ------------------------------------------------------------
# DOCKER / POSTGRESQL (используется docker-compose.yml)
# ------------------------------------------------------------

# Имя базы данных, пользователь и пароль для контейнера Postgres.
# При запуске через docker-compose DATABASE_URL подставляется автоматически.
POSTGRES_DB=django_db
POSTGRES_USER=django_user
POSTGRES_PASSWORD=django_pass

# ------------------------------------------------------------
# СТАТИКА И МЕДИА
# ------------------------------------------------------------

# Папка для collectstatic (относительно корня проекта).
# STATIC_ROOT=staticfiles

# Папка для загружаемых пользователем файлов.
# MEDIA_ROOT=media

# ------------------------------------------------------------
# ЛОКАЛИЗАЦИЯ
# ------------------------------------------------------------

# Язык интерфейса Django (админка, сообщения об ошибках)
LANGUAGE_CODE=ru

# Часовой пояс
TIME_ZONE=Asia/Almaty
